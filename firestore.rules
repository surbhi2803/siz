rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is in a room (simplified)
    function isInRoom(roomId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can create their own document
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can update their own document
      allow update: if isAuthenticated() && request.auth.uid == userId;
      
      // Users cannot delete their document (optional: you can allow this if needed)
      allow delete: if false;
    }
    
    // Rooms collection
    match /rooms/{roomId} {
      // Anyone authenticated can read rooms they're part of
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.memberIds;
      
      // Any authenticated user can create a room
      allow create: if isAuthenticated() && 
                       request.auth.uid in request.resource.data.memberIds;
      
      // Allow updates for joining rooms (adding members) or if already a member
      allow update: if isAuthenticated() && (
                       request.auth.uid in resource.data.memberIds ||
                       request.auth.uid in request.resource.data.memberIds
                     );
      
      // Only room members can delete the room
      allow delete: if isAuthenticated() && 
                       request.auth.uid in resource.data.memberIds;
    }
    
    // Expenses collection
    match /expenses/{expenseId} {
      // Anyone in the room can read expenses
      allow read: if isAuthenticated() && 
                     request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can create expenses
      allow create: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(request.resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can update expenses
      allow update: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can delete expenses
      allow delete: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
    }
    
    // Todos collection
    match /todos/{todoId} {
      // Anyone in the room can read todos
      allow read: if isAuthenticated() && 
                     request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can create todos
      allow create: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(request.resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can update todos
      allow update: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
      
      // Anyone in the room can delete todos
      allow delete: if isAuthenticated() && 
                       request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.memberIds;
    }
    
    // Invite codes collection
    match /inviteCodes/{code} {
      // Anyone authenticated can read invite codes
      allow read, write: if isAuthenticated();
    }
    
    // Invites collection (alternative naming)
    match /invites/{code} {
      // Anyone authenticated can read/write invites
      allow read, write: if isAuthenticated();
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
